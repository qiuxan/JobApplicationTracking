@using JobApplicationTracking.Domain.Entities
@using JobApplicationTracking.Application.DTOs
@model JobApplicationDto

@{
    ViewData["Title"] = $"{Model.Company} – {Model.Role}";

    var badgeClass = Model.Status switch
    {
        ApplicationStatus.Applied => "bg-primary",
        ApplicationStatus.PhoneScreen => "bg-info text-dark",
        ApplicationStatus.Interview => "bg-warning text-dark",
        ApplicationStatus.Offer => "bg-success",
        ApplicationStatus.Rejected => "bg-danger",
        ApplicationStatus.Withdrawn => "bg-secondary",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1>@Model.Role</h1>
        <h4 class="text-muted">@Model.Company</h4>
    </div>
    <span class="badge fs-6 @badgeClass">@Model.Status</span>
</div>
<hr />

<dl class="row">
    <dt class="col-sm-3">Applied</dt>
    <dd class="col-sm-9">@Model.AppliedDate.ToString("MMMM d, yyyy")</dd>

    @if (!string.IsNullOrEmpty(Model.JobUrl))
    {
        <dt class="col-sm-3">Job URL</dt>
        <dd class="col-sm-9"><a href="@Model.JobUrl" target="_blank">@Model.JobUrl</a></dd>
    }

    @if (!string.IsNullOrEmpty(Model.ContactName))
    {
        <dt class="col-sm-3">Contact</dt>
        <dd class="col-sm-9">
            @Model.ContactName
            @if (!string.IsNullOrEmpty(Model.ContactEmail))
            {
                <span class="text-muted ms-2">(@Model.ContactEmail)</span>
            }
        </dd>
    }

    @if (!string.IsNullOrEmpty(Model.Notes))
    {
        <dt class="col-sm-3">Notes</dt>
        <dd class="col-sm-9" style="white-space: pre-wrap;">@Model.Notes</dd>
    }

    <dt class="col-sm-3">Last Updated</dt>
    <dd class="col-sm-9">@Model.UpdatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</dd>
</dl>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Back to List</a>
</div>
